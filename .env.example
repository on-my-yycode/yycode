# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 提供商类型: anthropic 或 openai
PROVIDER=anthropic

# API 配置
API_KEY=your-api-key-here
API_BASE=https://api.anthropic.com

# 模型 ID
AI_MODEL=claude-3-5-sonnet-20241022

# 可选: 覆盖默认 skill 搜索目录，多个目录用逗号分隔
# agent 会通过 list_skills / load_skill 工具按需发现和加载 skill
# YOYO_SKILL_DIRS=skills,../shared-skills

# 可选: 覆盖模型上下文窗口大小，用于 yoyo >> 提示符百分比显示
# YOYO_CONTEXT_WINDOW_TOKENS=224000

# OpenAI 示例配置:
# PROVIDER=openai
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o
