# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 提供商类型: anthropic 或 openai
PROVIDER=anthropic

# API 配置
API_KEY=your-api-key-here
API_BASE=https://api.anthropic.com

# 模型 ID
AI_MODEL=claude-3-5-sonnet-20241022

# OpenAI 示例配置:
# PROVIDER=openai
# API_KEY=sk-...
# API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o
